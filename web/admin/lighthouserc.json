{
  "$schema": "https://googlechrome.github.io/lighthouse-ci/configuration",
  "ci": {
    "collect": {
      "startServerCommand": "npm run start -- --port 3100",
      "startServerReadyPattern": "Ready in",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://localhost:3100/dashboard",
        "http://localhost:3100/llm",
        "http://localhost:3100/persona",
        "http://localhost:3100/skills",
        "http://localhost:3100/cron",
        "http://localhost:3100/memory",
        "http://localhost:3100/secrets",
        "http://localhost:3100/channels",
        "http://localhost:3100/logs",
        "http://localhost:3100/audit",
        "http://localhost:3100/system"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless=new",
        "skipAudits": [
          "uses-http2",
          "is-on-https",
          "redirects-http",
          "uses-long-cache-ttl",
          "canonical"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:seo": "off",
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 200 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
