# SimpleClaw Admin 로컬 환경변수 예시.
# 실제 값은 `.env.local`에 복사해 사용한다 (`.env.local`은 git에 커밋하지 않는다).

# 기본 포트(8088) 외 다른 포트를 쓰고 싶을 때만 설정한다.
# Multica 웹 앱이 :3000을 점유하므로 SimpleClaw Admin은 기본 :8088을 사용한다.
# PORT=8200

# 데몬에서 발급받아 keyring에 저장된 admin_api_token을 그대로 옮긴다.
# 클라이언트 번들에는 절대 포함되지 않으며, /api/admin/[...path] 프록시에서만 사용된다.
ADMIN_API_TOKEN=

# 선택: 데몬 위치(기본 http://127.0.0.1:8082)
ADMIN_API_BASE=http://127.0.0.1:8082
