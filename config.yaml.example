llm:
  default: "gemini"
  providers:
    claude:
      type: "api"
      model: "claude-sonnet-4-20250514"
      # 시크릿 참조 문법:
      #   "env:NAME"       — OS 환경변수 NAME에서 읽기
      #   "keyring:NAME"   — macOS Keychain / Linux Secret Service에서 읽기
      #   "file:NAME"      — ~/.simpleclaw/secrets.enc 암호화 볼트에서 읽기
      # 평문 값(예: "sk-...")도 동작하지만 권장하지 않음. 자세한 사항은 README 참조.
      api_key: "keyring:claude_api_key"
    openai:
      type: "api"
      model: "gpt-4o"
      api_key: "keyring:openai_api_key"
    gemini:
      type: "api"
      model: "gemini-3-flash-preview"
      api_key: "env:GOOGLE_API_KEY"

agent:
  history_limit: 20
  db_path: ".agent/conversations.db"
  max_tool_iterations: 5
  workspace_dir: ".agent/workspace"

# 시맨틱 메모리 (RAG, spec 005 Phase 2)
# enabled: true 로 켜면 sentence-transformers가 첫 메시지에 모델(~500MB)을 다운로드한다.
# 다운로드 완료 후에는 시간 경계 밖 과거 대화도 의미 기반으로 회상된다.
memory:
  rag:
    enabled: false
    model: "intfloat/multilingual-e5-small"  # 한/영 동시 지원, 384dim, CPU 50ms
    top_k: 5                                  # 회상 후보 상위 K개
    similarity_threshold: 0.5                 # 코사인 유사도 임계값(노이즈 컷)

security:
  command_guard:
    enabled: true
    allowlist: []
  env_passthrough:
    - GOOGLE_API_KEY

skills:
  local_dir: ".agent/skills"
  global_dir: "~/.agents/skills"
  execution_timeout: 60

mcp:
  servers: {}

voice:
  stt:
    provider: "openai"
    model: "whisper-1"
    max_duration: 300
  tts:
    provider: "openai"
    model: "tts-1"
    voice: "alloy"
    speed: 1.0
    output_format: "mp3"
    max_text_length: 4096

telegram:
  # Telegram Bot Token (@BotFather 발급) — 시크릿 매니저 참조 권장.
  bot_token: "keyring:telegram_bot_token"
  whitelist:
    user_ids: []
    chat_ids: []

webhook:
  enabled: true
  host: "127.0.0.1"
  port: 8080
  auth_token: "keyring:webhook_auth_token"  # 웹훅 인증 토큰 (시크릿 매니저 참조)

sub_agents:
  max_concurrent: 3
  default_timeout: 300
  workspace_dir: "workspace/sub_agents"
  cleanup_workspace: false
  default_scope:
    allowed_paths: []
    network: false

daemon:
  heartbeat_interval: 300
  pid_file: ".agent/daemon.pid"
  status_file: ".agent/HEARTBEAT.md"
  db_path: ".agent/daemon.db"
  dreaming:
    overnight_hour: 3
    idle_threshold: 7200
    model: "gemini"
  wait_state:
    default_timeout: 3600
  # 크론 작업 재시도 정책 (BIZ-19) — 작업별 오버라이드 가능.
  # 일시적 네트워크/API 과부하에서 자동 복구하기 위한 기본값.
  # max_attempts=1 이면 재시도 없음. backoff_strategy: linear | exponential.
  # circuit_break_threshold=0 이면 누적 실패 차단 비활성.
  # 한 스케줄 트리거의 모든 재시도가 실패하면 누적 카운터가 1 증가하고,
  # 임계값에 도달하면 작업이 자동 비활성화되며 알림이 발송된다.
  cron_retry:
    max_attempts: 3
    backoff_seconds: 60
    backoff_strategy: "exponential"
    circuit_break_threshold: 5

persona:
  token_budget: 4096
  local_dir: ".agent"
  global_dir: "~/.agents/main"
  files:
    - name: "AGENT.md"
      type: "agent"
    - name: "USER.md"
      type: "user"
    - name: "MEMORY.md"
      type: "memory"
