llm:
  default: "gemini"
  providers:
    claude:
      type: "api"
      model: "claude-sonnet-4-20250514"
      # 시크릿 참조 문법:
      #   "env:NAME"       — OS 환경변수 NAME에서 읽기
      #   "keyring:NAME"   — macOS Keychain / Linux Secret Service에서 읽기
      #   "file:NAME"      — ~/.simpleclaw/secrets.enc 암호화 볼트에서 읽기
      # 평문 값(예: "sk-...")도 동작하지만 권장하지 않음. 자세한 사항은 README 참조.
      api_key: "keyring:claude_api_key"
    openai:
      type: "api"
      model: "gpt-4o"
      api_key: "keyring:openai_api_key"
    gemini:
      type: "api"
      model: "gemini-3.5-flash"
      api_key: "env:GOOGLE_API_KEY"

# BIZ-133 — 운영 데이터(SQLite, 페르소나 라이브 파일, dreaming sidecar 등)는 모두
# 저장소 working tree 외부 ``~/.simpleclaw/`` 로 이전됐다. git 작업과 dreaming
# 런타임 쓰기가 같은 디렉터리를 공유하지 않으므로 BIZ-28 류의 race window 가
# 구조적으로 사라진다. 다른 위치를 쓰고 싶으면 아래 키들을 수동으로 override.
agent:
  history_limit: 20
  db_path: "~/.simpleclaw/conversations.db"
  max_tool_iterations: 15
  workspace_dir: "~/.simpleclaw/workspace"
  # BIZ-162 — web_fetch 의 JS 렌더링 폴백에 쓰이는 `agent-browser` CLI 절대 경로.
  # null/미설정이면 PATH + 알려진 후보 경로(npm npx 캐시, fnm shim, brew 등)를
  # 자동 탐색한다. nohup/launchd/systemd 등 PATH 가 축소된 환경에서 명시적으로 지정.
  web_fetch:
    headless_binary: null
    # BIZ-187 — execute_skill 셸 명령에 ``agent-browser`` 가 들어가면 적용되는
    # 확장 타임아웃(초). SPA(wikidocs.net, npmjs.com 등)에서 ``open && wait && text``
    # composite 한 호출이 60s 의 기본 ``skills.execution_timeout`` 을 넘겨 tool loop
    # 가 죽는 패턴 봉합. 다른 명령은 기존 60s 가 유지된다. ``skills.execution_timeout``
    # 이상으로 두면 활성화, 이하면 자동으로 기본 타임아웃 유지.
    agent_browser_command_timeout: 180
  # BIZ-417 — web_fetch/headless가 Cloudflare/403으로 막힌 interactive URL 요청에서
  # 로컬 Chrome + Chrome Extension + Native Messaging으로 현재 탭 본문을 회수하는
  # handoff 기능. 기본은 disabled이며 cron/background에서는 Chrome을 열지 않는다.
  browser_handoff:
    enabled: false
    chrome_app: "Google Chrome"
    store_dir: "~/.simpleclaw-agent/default/browser-handoff"
    request_ttl_seconds: 600
    open_wait_seconds: 90
    max_extracted_chars: 50000
    native_host_name: "com.simpleclaw.browser_handoff"
    extension_id: null
    sensitive_domain_policy: "block"
    allow_auto_extract: false
  # BIZ-314 — 전체 skill/recipe 목록을 매 turn 시스템 프롬프트에 넣지 않고
  # selector top-k 또는 fallback cap만 노출해 prompt bloat와 잡담 도구 남용을 줄인다.
  asset_selection:
    enabled: true
    backend: "gemini"
    skill_top_k: 5
    recipe_top_k: 3
    min_confidence: 0.5
    bypass_below_count: 8
    fallback_top_k: 12
    max_tokens: 512
  # BIZ-384 — /goal foreground judge loop. Streaming text deltas are disabled inside
  # goal rounds; progress events only are emitted. Active-run /subgoal controls are
  # intentionally out of MVP scope.
  goal_loop:
    enabled: true
    max_rounds: 3
    judge_max_tokens: 768
    max_answer_chars_for_judge: 6000

# BIZ-202 — 레시피 디렉터리. 봇이 채팅에서 작성한 레시피와 데몬 cron 이 로드하는
# 레시피가 같은 절대 경로를 보도록 명시적으로 분리한 키. 기본은 ``~/.simpleclaw/recipes``
# — 봇 워크스페이스 sandbox-write 허용 트리 안에 들어가 봇이 직접 파일을 쓸 수 있다.
# 레거시 위치 ``.agent/recipes/`` 도 다음 마이너 릴리스까지는 한 번 폴백한다.
recipes:
  dir: "~/.simpleclaw/recipes"

# 시맨틱 메모리 (RAG, spec 005 Phase 2)
# enabled: true 로 켜면 sentence-transformers가 첫 메시지에 모델(~500MB)을 다운로드한다.
# 다운로드 완료 후에는 시간 경계 밖 과거 대화도 의미 기반으로 회상된다.
memory:
  rag:
    enabled: false
    model: "intfloat/multilingual-e5-small"  # 한/영 동시 지원, 384dim, CPU 50ms
    top_k: 5                                  # 회상 후보 상위 K개
    similarity_threshold: 0.5                 # 코사인 유사도 임계값(노이즈 컷)

# Agent Study Wiki — 사용자 기억(USER.md/MEMORY.md/insights)과 분리된 "외부 세계
# 배경지식" 저장소. 자동 브리핑 주제가 사용자 관심사로 과대 일반화되거나 낡은 외부
# 사실이 사용자 메모리처럼 영속되는 것을 막기 위한 경계다. 설계: docs/agent-study-wiki.md
# 모든 기능은 opt-in이며, 아래는 권장 기본값(현재는 config skeleton만 동작).
study:
  enabled: false
  wiki_dir: ~/.simpleclaw-agent/default/agent_wiki  # ~ 확장 후 Path로 정규화
  daily:                          # 매일 정해진 시각에 주제를 공부하는 배치
    enabled: false
    hour_kst: 6                   # 실행 시각(KST)
    max_topics_per_run: 8         # 1회 실행당 최대 주제 수
    max_sources_per_topic: 5      # 주제당 최대 출처 수
  retrieval:                      # 질문 응답 시 wiki를 맥락으로 주입
    enabled: false
    top_k: 4                      # 회상 후보 상위 K개
    max_context_chars: 5000       # 주입 컨텍스트 최대 길이
    freshness_hours:              # confidence별 신선도 허용치(시간)
      high: 24
      medium: 72
      low: 168
  topic_evolution:                # 주제 자동 생성/승격/소멸 정책
    auto_create: true
    min_interest_score: 0.55      # 주제 생성 최소 관심도
    promote_threshold: 0.70       # 상시 주제로 승격 임계값
    decay_after_days: 14          # 무관심 시 소멸까지의 일수
  safety:                         # 사실성 가드
    require_sources: true                     # 출처 없는 항목 금지
    low_confidence_requires_disclaimer: true  # 저신뢰 항목은 면책 문구 필수

security:
  # BIZ-302 후속 — EncryptedFileBackend가 사용하는 시크릿 볼트와 마스터 키 파일
  # 경로. 미지정 시 각각 ``~/.simpleclaw/secrets.enc`` / ``~/.simpleclaw/master.key``
  # (기존 기본값). 라이브 데이터 디렉터리(``~/.simpleclaw-agent/default``)로
  # 시크릿까지 분리하고 싶다면 아래처럼 명시한다.
  # vault_path: "~/.simpleclaw-agent/default/secrets.enc"
  # master_key_path: "~/.simpleclaw-agent/default/master.key"
  # 환경변수 ``SIMPLECLAW_MASTER_KEY``가 설정되어 있으면 마스터 키 파일보다 우선.
  command_guard:
    enabled: true
    allowlist: []
  env_passthrough:
    - GOOGLE_API_KEY
    - NAVER_CLIENT_ID
    - NAVER_CLIENT_SECRET

skills:
  local_dir: ".agent/skills"
  global_dir: "~/.agents/skills"
  execution_timeout: 60

# MCP (Model Context Protocol) — stdio 서버만 지원. 서버 변경은 restart 필요.
# scope: runtime  → 일반 사용자 tool loop에 노출 (명시적 opt-in)
# scope: operator → 운영자 context에서만 호출 가능 (기본값)
# env 값에는 env:/file:/keyring: 시크릿 참조를 사용할 수 있다.
mcp:
  enabled: false
  servers: {}
  # Example:
  # servers:
  #   time:
  #     transport: stdio
  #     command: "uvx"
  #     args: ["mcp-server-time"]
  #     scope: runtime
  #     timeout: 30
  #     connect_timeout: 20
  #     env: {}

voice:
  stt:
    provider: "openai"
    model: "whisper-1"
    max_duration: 300
  tts:
    provider: "openai"
    model: "tts-1"
    voice: "alloy"
    speed: 1.0
    output_format: "mp3"
    max_text_length: 4096

telegram:
  # Telegram Bot Token (@BotFather 발급) — 시크릿 매니저 참조 권장.
  bot_token: "keyring:telegram_bot_token"
  whitelist:
    user_ids: []
    chat_ids: []
  # BIZ-259 — LLM 응답 점진 스트리밍 (텔레그램 native draft + safe edit).
  # 기본 enabled=false (회귀 0 디폴트). 환경별로 켜고 끈다.
  # Phase 1: Claude 백엔드에서만 실제 스트리밍. Gemini/OpenAI/CLI 는 자동 fallback.
  streaming:
    # true 면 응답을 placeholder 로 먼저 보내고 editMessageText 로 점진 갱신.
    # false 면 기존 동작(완성 후 1회 sendMessage) 유지.
    enabled: false
    # editMessageText 최소 간격(ms). Telegram chat 당 ~1초/회 rate limit 회피용.
    min_interval_ms: 800
    # 이 글자 수만큼 새 토큰이 쌓여야 edit 호출 — 잦은 1~2자 갱신을 막아 시각 흔들림 완화.
    min_delta_chars: 40
    # 첫 메시지 본문 (스트리밍 시작 표시). 비워두지 말 것 — Telegram 은 빈 메시지 거부.
    initial_placeholder: "…"
    # Cron 트리거 응답은 강제로 비스트리밍 — 자동 알림이 부분 결과로 푸시되는 사고 방지.
    final_only_for_cron: true
    # true 면 tool/skill/command/recipe 실행 start/complete/fail 을 placeholder 에 표시.
    tool_progress: true

# Admin API (BIZ-41 / BIZ-58) — Admin UI 백엔드.
# 단일 운영자 가정으로 ``127.0.0.1`` 로컬 바인딩만 권장. 토큰은 시크릿 매니저 참조로
# 두는 것을 권장하며, ``token_secret``이 비어 있으면 봇 부팅 단계에서 즉시 실패한다
# (silent insecure 운용 방지).
#
# 토큰 발급 예시:
#   .venv/bin/python -c "
#   import secrets
#   from simpleclaw.security.secrets import SecretsManager
#   SecretsManager().store('keyring', 'admin_api_token', secrets.token_urlsafe(32))
#   "
#
# Admin UI(별도 dev 서버) 포트가 다를 경우 ``cors_origins``에 origin을 추가한다.
admin_api:
  enabled: true
  bind_host: "127.0.0.1"
  bind_port: 8082
  token_secret: "keyring:admin_api_token"
  read_timeout_seconds: 30
  request_max_body_kb: 256
  # Admin UI dev 서버 origin 을 명시한다 — 비어 있으면 브라우저 직호출이 CORS 로
  # 막혀 일부 페이지가 401/403 으로 깨진다(BIZ-246). 기본값은 현행 OLD admin
  # (web/admin, :8088) 과 admin-2 컷오버 대비(:8089) 두 origin 을 모두 허용한다.
  cors_origins:
    - "http://localhost:8088"  # web/admin (OLD)
    - "http://localhost:8089"  # web/admin-2 (cutover 대비)

webhook:
  enabled: true
  host: "127.0.0.1"
  port: 8080
  auth_token: "keyring:webhook_auth_token"  # 웹훅 인증 토큰 (시크릿 매니저 참조)
  # BIZ-24 보안 강화 — 페이로드 크기 / Rate Limit / 동시성 cap.
  # 공개 엔드포인트로 노출할 때는 아래 값을 워크로드에 맞게 조정한다.
  #   max_body_size: 정상 페이로드 최대 크기(bytes). 초과 시 413.
  #     기본 1MB는 일반 텍스트/JSON 이벤트엔 충분하며 첨부물은 별도 채널로 받는 것을 권장.
  #   rate_limit / rate_limit_window: 한 키(인증 시 토큰, 미인증 시 IP)당 윈도우 내 허용 요청 수.
  #     초과 시 429 + Retry-After. rate_limit=0 이면 비활성.
  #   max_concurrent_connections: 동시에 처리 가능한 요청 수.
  #   queue_size: 동시성 cap 초과 시 대기 가능한 요청 수. 큐 포화 시 503 + Retry-After.
  #   alert_cooldown: 동일 비정상 패턴(연속 차단/IP 폭주/큐 포화)에 대한 알림 발신 최소 간격(초).
  max_body_size: 1048576
  rate_limit: 60
  rate_limit_window: 60.0
  max_concurrent_connections: 32
  queue_size: 64
  alert_cooldown: 300.0

sub_agents:
  max_concurrent: 3
  default_timeout: 300
  workspace_dir: "workspace/sub_agents"
  cleanup_workspace: false
  default_scope:
    allowed_paths: []
    network: false

daemon:
  heartbeat_interval: 300
  pid_file: "~/.simpleclaw/daemon.pid"
  status_file: "~/.simpleclaw/HEARTBEAT.md"
  db_path: "~/.simpleclaw/daemon.db"
  dreaming:
    overnight_hour: 3
    idle_threshold: 7200
    model: "gemini"
    # Phase 3 그래프형 드리밍 — IncrementalClusterer가 미클러스터 임베딩을 부착하고
    # MEMORY.md의 ``<!-- cluster:N -->`` 마커 영역을 in-place 갱신한다. 기본값은 안전
    # 측면에서 ``False``이며 명시적으로 켜야 활성화된다.
    enable_clusters: true
    # 클러스터 부착 임계값(cosine) — multilingual-e5-small 기준. 낮추면 클러스터가 커
    # 지고(잡음↑·단일 메가 위험), 높이면 작아진다(파편화↑). BIZ-147 fine-tune 결과
    # 50메시지 / 한국어 일상 대화 데이터셋에서 0.88이 max<50% (22/50=44%) 를 만족하
    # 는 첫 값으로 관찰됐다. 0.86 이하에서는 ~70% 단일 mini-mega가 사라지지 않고,
    # 0.89 이상에서는 1-멤버 stragglers가 빠르게 늘어난다. 데이터셋이 다르면 0.86~0.92
    # 사이에서 재측정하는 것을 권장.
    cluster_threshold: 0.88
    # BIZ-73: 인사이트 승격 임계 관측 횟수. 단발 관측은 항상 confidence ≤ 0.4 로 캡되고,
    # 이 횟수에 도달해야 승격선(0.7)에 진입한다. 작은 값이면 빨리 승격(잘못된 일반화↑),
    # 큰 값이면 보수적(누적 신뢰성↑). 기본 3회.
    insight_promotion_threshold: 3
    # BIZ-78: 인사이트 decay 정책. last_seen 기준으로 N 일 이상 reinforcement 가
    # 없는 인사이트는 archive 처리되어 USER.md 의 archive 섹션으로 이동하고
    # sidecar 의 archived_at 이 기록된다. 같은 topic 이 다시 관측되면 자동 부활.
    # null/0/음수면 decay 비활성(모든 인사이트 유지). 기본 30일.
    decay:
      archive_after_days: 30
    # BIZ-78: 사용자가 reject 한 topic 의 재학습 차단 리스트.
    # default_ttl_days null 이면 영구 차단(가장 흔한 케이스). 양수면 N 일 후 자동 해제.
    # 항목별 override 는 Admin Review Loop(H, BIZ-79) 에서 가능.
    reject_blocklist:
      default_ttl_days: null
    # BIZ-79: Dry-run + Admin Review Loop.
    # dry_run=true 면 dreaming 이 발견한 인사이트는 곧바로 USER.md 에 반영되지 않고
    # ``insight_suggestions.jsonl`` 큐로 들어가 운영자 검수(Memory 화면)를 거친 뒤
    # accept/reject 된다. dry_run=false 는 BIZ-79 이전 동작(즉시 sidecar/USER.md 반영).
    # 단, ``auto_promote`` 두 조건(confidence AND evidence_count)을 동시 만족하는 항목은
    # dry_run 중에도 자동 승격되어 큐를 거치지 않는다 — 이미 충분히 강한 시그널의 경우
    # 운영자가 매번 반복 승인할 필요가 없도록.
    dry_run: true
    auto_promote:
      confidence: 0.7
      evidence_count: 3
    # BIZ-74 — USER.md의 ``managed:dreaming:active-projects`` 섹션을 매 사이클
    # in-place 갱신한다. 새 세션 첫 응답에서 "지금 집중 중인 프로젝트"를 0에서
    # 시작하지 않도록 하기 위함. 윈도우 외 항목은 sidecar에 남고 섹션에서만 빠진다.
    active_projects:
      enabled: true
      window_days: 7
      sidecar_path: "~/.simpleclaw/active_projects.jsonl"
    # BIZ-133 — dreaming sidecar 파일 경로. 운영 디렉터리(``~/.simpleclaw/``) 외부
    # 이전을 위해 모든 sidecar 위치를 명시 노출한다. 다른 마운트로 옮기고 싶으면
    # 아래 키를 override 하면 된다.
    insights_file: "~/.simpleclaw/insights.jsonl"
    suggestions_file: "~/.simpleclaw/suggestions.jsonl"
    blocklist_file: "~/.simpleclaw/insight_blocklist.jsonl"
    runs_file: "~/.simpleclaw/dreaming_runs.jsonl"
    # BIZ-132 / BIZ-133 — dreaming 사이클 직전 라이브 파일을 통째로 스냅샷.
    # 운영 데이터와 같은 루트 아래 두어 백업/복원이 동일 마운트 내에서 일어나도록.
    safety_backup_dir: "~/.simpleclaw/_safety_backup"
    # BIZ-80 — Dreaming 산출물의 1차 언어 정책. primary 가 USER/MEMORY/AGENT/SOUL
    # dreaming-managed 섹션의 출력 언어를 결정한다. 영어 입력 대화에서도 출력은
    # 1차 언어로 통일되어 retrieval 임베딩 일관성과 가독성이 확보된다.
    # primary: null 이면 enforcement 비활성(LLM 출력 그대로). 기본 "ko".
    # min_ratio: 한 항목 안의 한글/라틴 비율 임계치. 0.3 이면 "BIZ-66 진행" 같은
    #   ASCII 토큰이 섞인 한국어 bullet 도 통과한다. 너무 빡빡하면 정상 한국어
    #   bullet 까지 잘리니 유의.
    # per_file: 파일별 1차 언어 override. 예: {"agent": "en"} 이면 AGENT.md 만 영어.
    #   BIZ-80 표준은 USER/MEMORY/AGENT/SOUL 모두 ko (override 없음).
    language:
      primary: "ko"
      min_ratio: 0.3
      per_file: {}
    # BIZ-132 — 사이클 직전 safety backup 보존 사이클 수. 매 dreaming 사이클의
    # preflight 직전, 라이브 페르소나/sidecar/DB 가 ``.agent/_safety_backup/{ts}/``
    # 에 통째로 스냅샷된다. ``max_cycles`` 를 초과한 오래된 사이클은 자동 삭제되며,
    # ``가장 최근 1개는 항상 보존`` 보장은 0/음수 입력에서도 살아남는다.
    # 7개 보존이면 약 1주(일 1회 가정) — 사고가 발생해도 한 주 안에 운영자가
    # 인지/복원 가능한 시간을 확보한다.
    safety_backup_max_cycles: 7
  wait_state:
    default_timeout: 3600
  # 크론 작업 재시도 정책 (BIZ-19) — 작업별 오버라이드 가능.
  # 일시적 네트워크/API 과부하에서 자동 복구하기 위한 기본값.
  # max_attempts=1 이면 재시도 없음. backoff_strategy: linear | exponential.
  # circuit_break_threshold=0 이면 누적 실패 차단 비활성.
  # 한 스케줄 트리거의 모든 재시도가 실패하면 누적 카운터가 1 증가하고,
  # 임계값에 도달하면 작업이 자동 비활성화되며 알림이 발송된다.
  cron_retry:
    max_attempts: 3
    backoff_seconds: 60
    backoff_strategy: "exponential"
    circuit_break_threshold: 5
  # BIZ-332/334 — proactive 후보는 저장만 하며 presenter/policy가 별도 발송 판단.
  proactive:
    enabled: false
    mode: "low"
    store_file: "~/.simpleclaw-agent/default/proactive_opportunities.jsonl"
    extractors:
      dreaming:
        enabled: false
        # BIZ-356 — Dreaming 단계에서 최근 대화 + 향후 일정 + 최근 메일 metadata를
        # 모아 사용자 승인형 cron 후보를 만든다. 기본값은 fail-closed/off이며,
        # Telegram `등록` 승인 전에는 실제 CronScheduler side effect가 없다.
        context_cron:
          enabled: false
          conversation_lookback_hours: 24
          calendar_lookahead_hours: 24
          mail_lookback_hours: 24
          mail_query: "in:inbox newer_than:1d"
          calendar_id: "primary"
          calendar_limit: 10
          mail_limit: 10
          require_user_approval: true
          max_context_opportunities_per_run: 3
          allow_recurring: true
          allow_one_shot: true
          calendar_skill_path: "~/.agents/skills/google-calendar-skill"
          gmail_skill_path: "~/.agents/skills/gmail-skill"
      conversation_end:
        enabled: false
        max_latency_ms: 50
    event_hooks:
      enabled: false
      cron_failure:
        enabled: false

persona:
  token_budget: 4096
  # BIZ-302 — 페르소나 base folder 기본값. 개발 트리(~/Dev/SimpleClaw) / 배포 트리
  # (~/.simpleclaw)와 분리된 별도 위치를 사용한다.
  # 기존 ``~/.simpleclaw`` 에 있던 파일은 ``scripts/migrate_local_dir.py --target
  # ~/.simpleclaw-agent/default`` 로 이전 가능.
  local_dir: "~/.simpleclaw-agent/default"
  global_dir: "~/.agents/main"
  files:
    - name: "AGENT.md"
      type: "agent"
    - name: "USER.md"
      type: "user"
    - name: "MEMORY.md"
      type: "memory"
