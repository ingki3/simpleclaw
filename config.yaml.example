llm:
  default: "gemini"
  providers:
    claude:
      type: "api"
      model: "claude-sonnet-4-20250514"
      # 시크릿 참조 문법:
      #   "env:NAME"       — OS 환경변수 NAME에서 읽기
      #   "keyring:NAME"   — macOS Keychain / Linux Secret Service에서 읽기
      #   "file:NAME"      — ~/.simpleclaw/secrets.enc 암호화 볼트에서 읽기
      # 평문 값(예: "sk-...")도 동작하지만 권장하지 않음. 자세한 사항은 README 참조.
      api_key: "keyring:claude_api_key"
    openai:
      type: "api"
      model: "gpt-4o"
      api_key: "keyring:openai_api_key"
    gemini:
      type: "api"
      model: "gemini-3-flash-preview"
      api_key: "env:GOOGLE_API_KEY"

# BIZ-133 — 운영 데이터(SQLite, 페르소나 라이브 파일, dreaming sidecar 등)는 모두
# 저장소 working tree 외부 ``~/.simpleclaw/`` 로 이전됐다. git 작업과 dreaming
# 런타임 쓰기가 같은 디렉터리를 공유하지 않으므로 BIZ-28 류의 race window 가
# 구조적으로 사라진다. 다른 위치를 쓰고 싶으면 아래 키들을 수동으로 override.
agent:
  history_limit: 20
  db_path: "~/.simpleclaw/conversations.db"
  max_tool_iterations: 5
  workspace_dir: "~/.simpleclaw/workspace"

# 시맨틱 메모리 (RAG, spec 005 Phase 2)
# enabled: true 로 켜면 sentence-transformers가 첫 메시지에 모델(~500MB)을 다운로드한다.
# 다운로드 완료 후에는 시간 경계 밖 과거 대화도 의미 기반으로 회상된다.
memory:
  rag:
    enabled: false
    model: "intfloat/multilingual-e5-small"  # 한/영 동시 지원, 384dim, CPU 50ms
    top_k: 5                                  # 회상 후보 상위 K개
    similarity_threshold: 0.5                 # 코사인 유사도 임계값(노이즈 컷)

security:
  command_guard:
    enabled: true
    allowlist: []
  env_passthrough:
    - GOOGLE_API_KEY
    - NAVER_CLIENT_ID
    - NAVER_CLIENT_SECRET

skills:
  local_dir: ".agent/skills"
  global_dir: "~/.agents/skills"
  execution_timeout: 60

mcp:
  servers: {}

voice:
  stt:
    provider: "openai"
    model: "whisper-1"
    max_duration: 300
  tts:
    provider: "openai"
    model: "tts-1"
    voice: "alloy"
    speed: 1.0
    output_format: "mp3"
    max_text_length: 4096

telegram:
  # Telegram Bot Token (@BotFather 발급) — 시크릿 매니저 참조 권장.
  bot_token: "keyring:telegram_bot_token"
  whitelist:
    user_ids: []
    chat_ids: []

# Admin API (BIZ-41 / BIZ-58) — Admin UI 백엔드.
# 단일 운영자 가정으로 ``127.0.0.1`` 로컬 바인딩만 권장. 토큰은 시크릿 매니저 참조로
# 두는 것을 권장하며, ``token_secret``이 비어 있으면 봇 부팅 단계에서 즉시 실패한다
# (silent insecure 운용 방지).
#
# 토큰 발급 예시:
#   .venv/bin/python -c "
#   import secrets
#   from simpleclaw.security.secrets import SecretsManager
#   SecretsManager().store('keyring', 'admin_api_token', secrets.token_urlsafe(32))
#   "
#
# Admin UI(별도 dev 서버) 포트가 다를 경우 ``cors_origins``에 origin을 추가한다.
admin_api:
  enabled: true
  bind_host: "127.0.0.1"
  bind_port: 8082
  token_secret: "keyring:admin_api_token"
  read_timeout_seconds: 30
  request_max_body_kb: 256
  cors_origins: []  # 예: ["http://localhost:8088"]

webhook:
  enabled: true
  host: "127.0.0.1"
  port: 8080
  auth_token: "keyring:webhook_auth_token"  # 웹훅 인증 토큰 (시크릿 매니저 참조)
  # BIZ-24 보안 강화 — 페이로드 크기 / Rate Limit / 동시성 cap.
  # 공개 엔드포인트로 노출할 때는 아래 값을 워크로드에 맞게 조정한다.
  #   max_body_size: 정상 페이로드 최대 크기(bytes). 초과 시 413.
  #     기본 1MB는 일반 텍스트/JSON 이벤트엔 충분하며 첨부물은 별도 채널로 받는 것을 권장.
  #   rate_limit / rate_limit_window: 한 키(인증 시 토큰, 미인증 시 IP)당 윈도우 내 허용 요청 수.
  #     초과 시 429 + Retry-After. rate_limit=0 이면 비활성.
  #   max_concurrent_connections: 동시에 처리 가능한 요청 수.
  #   queue_size: 동시성 cap 초과 시 대기 가능한 요청 수. 큐 포화 시 503 + Retry-After.
  #   alert_cooldown: 동일 비정상 패턴(연속 차단/IP 폭주/큐 포화)에 대한 알림 발신 최소 간격(초).
  max_body_size: 1048576
  rate_limit: 60
  rate_limit_window: 60.0
  max_concurrent_connections: 32
  queue_size: 64
  alert_cooldown: 300.0

sub_agents:
  max_concurrent: 3
  default_timeout: 300
  workspace_dir: "workspace/sub_agents"
  cleanup_workspace: false
  default_scope:
    allowed_paths: []
    network: false

daemon:
  heartbeat_interval: 300
  pid_file: "~/.simpleclaw/daemon.pid"
  status_file: "~/.simpleclaw/HEARTBEAT.md"
  db_path: "~/.simpleclaw/daemon.db"
  dreaming:
    overnight_hour: 3
    idle_threshold: 7200
    model: "gemini"
    # BIZ-73: 인사이트 승격 임계 관측 횟수. 단발 관측은 항상 confidence ≤ 0.4 로 캡되고,
    # 이 횟수에 도달해야 승격선(0.7)에 진입한다. 작은 값이면 빨리 승격(잘못된 일반화↑),
    # 큰 값이면 보수적(누적 신뢰성↑). 기본 3회.
    insight_promotion_threshold: 3
    # BIZ-78: 인사이트 decay 정책. last_seen 기준으로 N 일 이상 reinforcement 가
    # 없는 인사이트는 archive 처리되어 USER.md 의 archive 섹션으로 이동하고
    # sidecar 의 archived_at 이 기록된다. 같은 topic 이 다시 관측되면 자동 부활.
    # null/0/음수면 decay 비활성(모든 인사이트 유지). 기본 30일.
    decay:
      archive_after_days: 30
    # BIZ-78: 사용자가 reject 한 topic 의 재학습 차단 리스트.
    # default_ttl_days null 이면 영구 차단(가장 흔한 케이스). 양수면 N 일 후 자동 해제.
    # 항목별 override 는 Admin Review Loop(H, BIZ-79) 에서 가능.
    reject_blocklist:
      default_ttl_days: null
    # BIZ-79: Dry-run + Admin Review Loop.
    # dry_run=true 면 dreaming 이 발견한 인사이트는 곧바로 USER.md 에 반영되지 않고
    # ``insight_suggestions.jsonl`` 큐로 들어가 운영자 검수(Memory 화면)를 거친 뒤
    # accept/reject 된다. dry_run=false 는 BIZ-79 이전 동작(즉시 sidecar/USER.md 반영).
    # 단, ``auto_promote`` 두 조건(confidence AND evidence_count)을 동시 만족하는 항목은
    # dry_run 중에도 자동 승격되어 큐를 거치지 않는다 — 이미 충분히 강한 시그널의 경우
    # 운영자가 매번 반복 승인할 필요가 없도록.
    dry_run: true
    auto_promote:
      confidence: 0.7
      evidence_count: 3
    # BIZ-74 — USER.md의 ``managed:dreaming:active-projects`` 섹션을 매 사이클
    # in-place 갱신한다. 새 세션 첫 응답에서 "지금 집중 중인 프로젝트"를 0에서
    # 시작하지 않도록 하기 위함. 윈도우 외 항목은 sidecar에 남고 섹션에서만 빠진다.
    active_projects:
      enabled: true
      window_days: 7
      sidecar_path: "~/.simpleclaw/active_projects.jsonl"
    # BIZ-133 — dreaming sidecar 파일 경로. 운영 디렉터리(``~/.simpleclaw/``) 외부
    # 이전을 위해 모든 sidecar 위치를 명시 노출한다. 다른 마운트로 옮기고 싶으면
    # 아래 키를 override 하면 된다.
    insights_file: "~/.simpleclaw/insights.jsonl"
    suggestions_file: "~/.simpleclaw/suggestions.jsonl"
    blocklist_file: "~/.simpleclaw/insight_blocklist.jsonl"
    runs_file: "~/.simpleclaw/dreaming_runs.jsonl"
    # BIZ-132 / BIZ-133 — dreaming 사이클 직전 라이브 파일을 통째로 스냅샷.
    # 운영 데이터와 같은 루트 아래 두어 백업/복원이 동일 마운트 내에서 일어나도록.
    safety_backup_dir: "~/.simpleclaw/_safety_backup"
    # BIZ-80 — Dreaming 산출물의 1차 언어 정책. primary 가 USER/MEMORY/AGENT/SOUL
    # dreaming-managed 섹션의 출력 언어를 결정한다. 영어 입력 대화에서도 출력은
    # 1차 언어로 통일되어 retrieval 임베딩 일관성과 가독성이 확보된다.
    # primary: null 이면 enforcement 비활성(LLM 출력 그대로). 기본 "ko".
    # min_ratio: 한 항목 안의 한글/라틴 비율 임계치. 0.3 이면 "BIZ-66 진행" 같은
    #   ASCII 토큰이 섞인 한국어 bullet 도 통과한다. 너무 빡빡하면 정상 한국어
    #   bullet 까지 잘리니 유의.
    # per_file: 파일별 1차 언어 override. 예: {"agent": "en"} 이면 AGENT.md 만 영어.
    #   BIZ-80 표준은 USER/MEMORY/AGENT/SOUL 모두 ko (override 없음).
    language:
      primary: "ko"
      min_ratio: 0.3
      per_file: {}
  wait_state:
    default_timeout: 3600
  # 크론 작업 재시도 정책 (BIZ-19) — 작업별 오버라이드 가능.
  # 일시적 네트워크/API 과부하에서 자동 복구하기 위한 기본값.
  # max_attempts=1 이면 재시도 없음. backoff_strategy: linear | exponential.
  # circuit_break_threshold=0 이면 누적 실패 차단 비활성.
  # 한 스케줄 트리거의 모든 재시도가 실패하면 누적 카운터가 1 증가하고,
  # 임계값에 도달하면 작업이 자동 비활성화되며 알림이 발송된다.
  cron_retry:
    max_attempts: 3
    backoff_seconds: 60
    backoff_strategy: "exponential"
    circuit_break_threshold: 5

persona:
  token_budget: 4096
  # BIZ-133 — 페르소나 라이브 파일(AGENT/USER/MEMORY/SOUL.md) 위치. 저장소 외부
  # 운영 디렉터리로 이전됐다. 새 환경에서는 ``scripts/migrate_local_dir.py`` 가
  # ``.agent/`` 의 기존 파일을 이 위치로 옮겨준다.
  local_dir: "~/.simpleclaw"
  global_dir: "~/.agents/main"
  files:
    - name: "AGENT.md"
      type: "agent"
    - name: "USER.md"
      type: "user"
    - name: "MEMORY.md"
      type: "memory"
