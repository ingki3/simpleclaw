{
  "manifest_version": 3,
  "name": "SimpleClaw Page Reader",
  "version": "0.1.0",
  "description": "Send the current page text to the local SimpleClaw runtime after user approval.",
  "permissions": ["activeTab", "scripting", "nativeMessaging"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {"service_worker": "background.js"},
  "action": {
    "default_title": "Send page to SimpleClaw",
    "default_popup": "popup.html"
  }
}
